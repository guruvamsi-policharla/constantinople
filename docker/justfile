# Mount Constantinople plus its sibling Commonware checkout. Cargo resolves
# `../monorepo` (the `commonware-privacy` path dep and the codec/macros/parallel
# `[patch.crates-io]` targets) from `/constantinople` to `/monorepo` inside the
# builder container. The checkout must be on the gv-privacy-2026.7 branch
# (v2026.7.0 + the privacy crate); a missing/wrong checkout breaks the build
# with confusing errors.
source-mounts := "-v ${PWD}:/constantinople -v ${PWD}/../monorepo:/monorepo:ro -v ${PWD}/.docker-cache/cargo:/cargo-home -v ${PWD}/.docker-cache/target:/constantinople/target"
cache-env := "-e CARGO_HOME=/cargo-home"

# Cargo features for the cluster binaries (validator + indexers) and the spammer.
# Empty builds the default mock backend. For the zkpari + simulator deploy, use
# the `graviton-binaries-zkpari` / `intel-binaries-zkpari` recipes, or override
# these on the CLI, e.g.
#   just cluster-features="constantinople-primitives/privacy-backend-zkpari" \
#        spammer-features="constantinople-primitives/privacy-backend-zkpari,constantinople-spammer/privacy-backend-simulator" \
#        graviton-binaries
cluster-features := ""
spammer-features := ""

prepare-docker-cache:
  mkdir -p .docker-cache/cargo .docker-cache/target

# Build the Graviton Docker builder image
build-graviton-image:
  docker buildx bake --progress plain -f docker/docker-bake.hcl graviton

# Build the ARM64 validator binary into deploy/
validator-graviton-binary: build-graviton-image prepare-docker-cache
  docker run --rm {{source-mounts}} {{cache-env}} \
    -e PACKAGE_NAME=constantinople-validator \
    -e BINARY_NAME=constantinople \
    -e OUTPUT_NAME=validator \
    -e FEATURES={{cluster-features}} \
    constantinople-builder:graviton-local

# Build the ARM64 spammer binary into deploy/
spammer-graviton-binary: build-graviton-image prepare-docker-cache
  docker run --rm {{source-mounts}} {{cache-env}} \
    -e PACKAGE_NAME=constantinople-spammer \
    -e BINARY_NAME=constantinople-spammer \
    -e OUTPUT_NAME=spammer \
    -e FEATURES={{spammer-features}} \
    constantinople-builder:graviton-local

# Build the ARM64 chain-indexer binary into deploy/
chain-indexer-graviton-binary: build-graviton-image prepare-docker-cache
  docker run --rm {{source-mounts}} {{cache-env}} \
    -e PACKAGE_NAME=constantinople-indexer \
    -e BINARY_NAME=chain-indexer \
    -e OUTPUT_NAME=chain-indexer \
    -e FEATURES={{cluster-features}} \
    constantinople-builder:graviton-local

# Build the ARM64 metadata-indexer binary into deploy/
metadata-indexer-graviton-binary: build-graviton-image prepare-docker-cache
  docker run --rm {{source-mounts}} {{cache-env}} \
    -e PACKAGE_NAME=constantinople-indexer \
    -e BINARY_NAME=metadata-indexer \
    -e OUTPUT_NAME=metadata-indexer \
    -e FEATURES={{cluster-features}} \
    constantinople-builder:graviton-local

# Build the ARM64 qmdb-indexer binary into deploy/
qmdb-indexer-graviton-binary: build-graviton-image prepare-docker-cache
  docker run --rm {{source-mounts}} {{cache-env}} \
    -e PACKAGE_NAME=constantinople-indexer \
    -e BINARY_NAME=qmdb-indexer \
    -e OUTPUT_NAME=qmdb-indexer \
    -e FEATURES={{cluster-features}} \
    constantinople-builder:graviton-local

# Build all ARM64 binaries into deploy/ (mock backend unless features overridden)
graviton-binaries: validator-graviton-binary spammer-graviton-binary chain-indexer-graviton-binary metadata-indexer-graviton-binary qmdb-indexer-graviton-binary

# Build all ARM64 binaries with the zkpari cluster + simulator-spammer backends.
graviton-binaries-zkpari:
  just cluster-features="constantinople-primitives/privacy-backend-zkpari" spammer-features="constantinople-primitives/privacy-backend-zkpari,constantinople-spammer/privacy-backend-simulator" graviton-binaries

# Build the Intel/C8i Docker builder image
build-intel-image:
  docker buildx bake --progress plain -f docker/docker-bake.hcl intel

# Build the Intel validator binary into deploy/
