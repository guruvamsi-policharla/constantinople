# Build all Intel binaries into deploy/ (mock backend unless features overridden)
intel-binaries: validator-intel-binary spammer-intel-binary chain-indexer-intel-binary metadata-indexer-intel-binary qmdb-indexer-intel-binary

# Build all Intel binaries with the zkpari cluster + simulator-spammer backends.
intel-binaries-zkpari:
  just cluster-features="constantinople-primitives/privacy-backend-zkpari" spammer-features="constantinople-primitives/privacy-backend-zkpari,constantinople-spammer/privacy-backend-simulator" intel-binaries
