# Build the Graviton Docker builder image
build-graviton-image:
  docker buildx bake --progress plain -f docker/docker-bake.hcl graviton

# Build the ARM64 validator binary into deploy/
validator-graviton-binary: build-graviton-image
  docker run --rm -v ${PWD}:/constantinople \
    -e PACKAGE_NAME=constantinople-validator \
    -e BINARY_NAME=constantinople \
    -e OUTPUT_NAME=validator \
    constantinople-builder:graviton-local

# Build the ARM64 spammer binary into deploy/
spammer-graviton-binary: build-graviton-image
  docker run --rm -v ${PWD}:/constantinople \
    -e PACKAGE_NAME=constantinople-spammer \
    -e BINARY_NAME=constantinople-spammer \
    -e OUTPUT_NAME=spammer \
    constantinople-builder:graviton-local

# Build the ARM64 relayer binary into deploy/
relayer-graviton-binary: build-graviton-image
  docker run --rm -v ${PWD}:/constantinople \
    -e PACKAGE_NAME=constantinople-relayer \
    -e BINARY_NAME=constantinople-relayer \
    -e OUTPUT_NAME=relayer \
    constantinople-builder:graviton-local

# Build the ARM64 chain-indexer binary into deploy/
chain-indexer-graviton-binary: build-graviton-image
  docker run --rm -v ${PWD}:/constantinople \
    -e PACKAGE_NAME=constantinople-indexer \
    -e BINARY_NAME=chain-indexer \
    -e OUTPUT_NAME=chain-indexer \
    constantinople-builder:graviton-local

# Build the ARM64 metadata-indexer binary into deploy/
metadata-indexer-graviton-binary: build-graviton-image
  docker run --rm -v ${PWD}:/constantinople \
    -e PACKAGE_NAME=constantinople-indexer \
    -e BINARY_NAME=metadata-indexer \
    -e OUTPUT_NAME=metadata-indexer \
    constantinople-builder:graviton-local

# Build all ARM64 binaries into deploy/
graviton-binaries: validator-graviton-binary spammer-graviton-binary relayer-graviton-binary chain-indexer-graviton-binary metadata-indexer-graviton-binary

# Build the Intel/C8i Docker builder image
