{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2023", "DOM"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "outDir": "dist-test",
        "rootDir": ".",
        "types": ["node"]
    },
    "include": [
        "tests/**/*.ts",
        "src/blockSequence.ts",
        "src/codec.ts",
        "src/historyKey.ts",
        "src/proofMath.ts",
        "src/proofRetry.ts"
    ]
}
